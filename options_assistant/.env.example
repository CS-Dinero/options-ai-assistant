# options_assistant — environment variables
# Copy this file to .env and fill in your real values
# NEVER commit .env to git

# ── Encoding (Windows) ───────────────────────
PYTHONIOENCODING=utf-8

# ── Massive (Polygon.io rebranded) ───────────
# Get your key from: massive.com/dashboard/keys → REST API tab
# Your Access Key ID goes here (NOT the Secret Access Key — that's for S3/flat files)
MASSIVE_API_KEY=your_rest_api_key_here

# ── Tradier (when account clears) ────────────
# Sandbox:    https://sandbox.tradier.com/v1
# Production: https://api.tradier.com/v1
TRADIER_TOKEN=your_tradier_token_here
TRADIER_BASE_URL=https://sandbox.tradier.com/v1
